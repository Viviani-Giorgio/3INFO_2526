
table {
    border-collapse: collapse;
    margin: 20px auto;
}

td {
    width: 50px;
    height: 50px;
    text-align: center;
    border: 1px solid #ccc;
}


tr:nth-child(odd) td:nth-child(even) {
    background-color: black;
    color: white;
}


tr:nth-child(even) td:nth-child(odd) {
    background-color: black;
    color: white;
}